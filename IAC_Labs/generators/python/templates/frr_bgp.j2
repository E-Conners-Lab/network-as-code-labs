{# BGP EVPN overlay configuration.
   Route reflectors get bgp cluster-id and treat non-RR peers as clients.
   Non-RR devices peer only with route reflectors.
#}
!
! --- BGP EVPN Overlay ---
!
router bgp {{ device.asn }}
 bgp router-id {{ device.loopback.ip }}
 no bgp default ipv4-unicast
 bgp bestpath as-path multipath-relax
 timers bgp {{ bgp.timers.keepalive }} {{ bgp.timers.holdtime }}
{% if rr %}
 bgp cluster-id {{ rr.cluster_id }}
{% endif %}
 !
{% for neighbor in neighbors %}
 neighbor {{ neighbor.ip }} remote-as {{ device.asn }}
 neighbor {{ neighbor.ip }} update-source lo
 neighbor {{ neighbor.ip }} description {{ neighbor.peer_device }}
{% if rr and not neighbor.is_rr %}
 neighbor {{ neighbor.ip }} route-reflector-client
{% endif %}
{% endfor %}
 !
 address-family ipv4 unicast
{% for neighbor in neighbors %}
  neighbor {{ neighbor.ip }} activate
{% endfor %}
 exit-address-family
 !
 address-family l2vpn evpn
{% for neighbor in neighbors %}
  neighbor {{ neighbor.ip }} activate
{% endfor %}
 exit-address-family
!
