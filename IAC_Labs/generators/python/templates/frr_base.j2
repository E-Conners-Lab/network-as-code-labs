{# Base FRR configuration template.
   Composes all section templates into a complete frr.conf for one device.
   Context variables:
     device    - Device model instance (name, role, loopback, management_ip, asn)
     links     - list of dicts with interface, ip, peer_device, mtu, description
     ospf      - OSPFConfig model instance
     bgp       - BGPConfig model instance
     neighbors - list of dicts with ip, role, is_rr, is_rr_client
     rr        - RouteReflector instance if this device is an RR, else None
     vrfs      - list of VRFConfig instances assigned to this device
     networks  - list of NetworkSegment instances assigned to this device
     interfaces - list of InterfaceAssignment instances for this device
     defaults  - DefaultsModel instance
#}
!
! FRR configuration for {{ device.name }}
! Role: {{ device.role.value }}
! Generated by Network as Code -- do not edit manually
!
frr version 10.3.1
frr defaults datacenter
hostname {{ device.name }}
log syslog informational
service integrated-vtysh-config
!
{% include 'frr_interfaces.j2' %}
{% include 'frr_ospf.j2' %}
{% include 'frr_bgp.j2' %}
{% if vrfs %}
{% include 'frr_vrf.j2' %}
{% endif %}
!
line vty
!
