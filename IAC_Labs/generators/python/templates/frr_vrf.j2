{# VRF and EVPN configuration for leaf and border devices.
   Defines VRF instances with L3VNI binding, configures per-VRF BGP
   routing with redistribute connected so SVI subnets are advertised
   as EVPN Type-5 routes, and sets up VXLAN-to-VRF mappings under
   the global BGP instance.
#}
!
! --- VRF Definitions ---
!
{% for vrf in vrfs %}
vrf {{ vrf.name }}
 vni {{ vrf.vni }}
!
{% endfor %}
!
! --- EVPN VRF Configuration ---
!
router bgp {{ device.asn }}
{% for vrf in vrfs %}
 !
 address-family l2vpn evpn
  vni {{ vrf.vni }}
   rd {{ vrf.rd }}
{% for rt in vrf.rt_import %}
   route-target import {{ rt }}
{% endfor %}
{% for rt in vrf.rt_export %}
   route-target export {{ rt }}
{% endfor %}
  exit-vni
 exit-address-family
{% endfor %}
!
{% for vrf in vrfs %}
router bgp {{ device.asn }} vrf {{ vrf.name }}
 !
 address-family ipv4 unicast
  redistribute connected
 exit-address-family
 !
 address-family l2vpn evpn
  advertise ipv4 unicast
 exit-address-family
!
{% endfor %}
{% if networks %}
! --- Network Segments (VXLAN) ---
! VXLAN dataplane config requires Linux bridge/ip commands outside vtysh.
! On a production EVPN switch these are native; in ContainerLab they are
! configured via the host OS networking stack.
!
{% for net in networks %}
! {{ net.name }}: VLAN {{ net.vlan_id }}, VNI {{ net.vni }}, {{ net.subnet }}
!   gateway: {{ net.gateway }}/{{ net.subnet.prefixlen }}
!   vrf: {{ net.vrf }}
{% endfor %}
{% endif %}
