{# VRF and EVPN configuration for leaf and border devices.
   The VRF routing configuration (BGP address-family) is managed
   through vtysh. The VXLAN dataplane configuration (vxlan interfaces,
   bridge mappings, anycast gateways) is platform-specific and handled
   at the OS level on real switches. In this lab we include the
   dataplane config as comments for documentation purposes.
#}
!
! --- VRF Routing ---
!
router bgp {{ device.asn }}
{% for vrf in vrfs %}
 !
 address-family l2vpn evpn
  vni {{ vrf.vni }}
   rd {{ vrf.rd }}
{% for rt in vrf.rt_import %}
   route-target import {{ rt }}
{% endfor %}
{% for rt in vrf.rt_export %}
   route-target export {{ rt }}
{% endfor %}
  exit-vni
 exit-address-family
{% endfor %}
!
{% if networks %}
! --- Network Segments (reference) ---
! The following VXLAN dataplane config is platform-specific.
! On a real EVPN switch, these commands create the VXLAN tunnels,
! bridge mappings, and anycast gateways. In ContainerLab with FRR,
! these would be configured via Linux bridge/ip commands outside vtysh.
!
{% for net in networks %}
! {{ net.name }}: VLAN {{ net.vlan_id }}, VNI {{ net.vni }}, {{ net.subnet }}
!   gateway: {{ net.gateway }}/{{ net.subnet.prefixlen }}
!   vrf: {{ net.vrf }}
{% endfor %}
{% endif %}
