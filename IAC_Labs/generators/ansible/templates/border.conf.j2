{# Border leaf FRR configuration. Same peering as leaf (RR clients only). #}
!
! FRR configuration for {{ inventory_hostname }}
! Role: border_leaf
! Generated by Ansible -- do not edit manually
!
frr version 10.3.1
frr defaults datacenter
hostname {{ inventory_hostname }}
log syslog informational
service integrated-vtysh-config
!
interface lo
 ip address {{ loopback }}
 description {{ defaults.description_prefix }} loopback
!
{% for link in fabric_links %}
interface {{ link.interface }}
 ip address {{ link.ip }}
 mtu {{ defaults.fabric_link_mtu }}
 description {{ defaults.description_prefix }} to {{ link.peer }} {{ link.peer_intf }}
 ip ospf network point-to-point
 ip ospf area {{ ospf.area }}
 ip ospf hello-interval {{ ospf.hello_interval }}
 ip ospf dead-interval {{ ospf.dead_interval }}
!
{% endfor %}
router ospf
 ospf router-id {{ loopback_ip }}
 auto-cost reference-bandwidth {{ ospf.reference_bandwidth }}
 passive-interface lo
 network {{ loopback }} area {{ ospf.area }}
{% for link in fabric_links %}
 network {{ link.ip }} area {{ ospf.area }}
{% endfor %}
!
router bgp {{ asn }}
 bgp router-id {{ loopback_ip }}
 no bgp default ipv4-unicast
 bgp bestpath as-path multipath-relax
 timers bgp {{ bgp.keepalive }} {{ bgp.holdtime }}
 !
{% for rr in route_reflector_peers %}
 neighbor {{ rr.ip }} remote-as {{ asn }}
 neighbor {{ rr.ip }} update-source lo
 neighbor {{ rr.ip }} description {{ rr.name }}
{% endfor %}
 !
 address-family ipv4 unicast
{% for rr in route_reflector_peers %}
  neighbor {{ rr.ip }} activate
{% endfor %}
 exit-address-family
 !
 address-family l2vpn evpn
{% for rr in route_reflector_peers %}
  neighbor {{ rr.ip }} activate
{% endfor %}
 exit-address-family
!
line vty
!
